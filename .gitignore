# ========================
# SAHARA — .gitignore
# ========================

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
venv/
env/
.env
*.egg-info/
dist/
build/
.pytest_cache/

# Node / React
node_modules/
dist/
.next/
.cache/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files (NEVER commit these)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/.env
frontend/.env

# Firebase
serviceAccountKey.json
*firebase*.json
!firebase.json

# ML models (large files — use Git LFS or store separately)
ml/models/*.pkl
ml/models/*.h5
ml/models/*.joblib
ml/data/*.csv
ml/data/*.zip

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
